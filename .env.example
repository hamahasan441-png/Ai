# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  Ai — Environment Variables                                                  ║
# ║                                                                              ║
# ║  Copy this file to .env and fill in the values.                              ║
# ║  DO NOT commit your .env file to version control.                            ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ── Required ──

# Anthropic API key for Claude (required for cloud AI features)
ANTHROPIC_API_KEY=

# ── Optional: Alternative Cloud Providers ──

# Use AWS Bedrock instead of direct Anthropic API
# CLAUDE_CODE_USE_BEDROCK=1

# Use Google Vertex AI instead of direct Anthropic API
# CLAUDE_CODE_USE_VERTEX=1

# OpenAI API key (for DevBrain hybrid mode)
# OPENAI_API_KEY=

# ── Optional: Database Connections ──

# PostgreSQL connection string (for DatabaseTool)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# MySQL connection string (for DatabaseTool)
# MYSQL_URL=mysql://user:password@localhost:3306/dbname

# ── Optional: Features ──

# Enable disk caching for AI responses (default: true)
# AI_CACHE_DISK=true

# Cache directory (default: ~/.cache/ai)
# AI_CACHE_DIR=

# Brain state directory (default: ~/.local/share/ai)
# AI_DATA_DIR=

# ── Optional: Development ──

# Node environment (development/production/test)
NODE_ENV=development

# Enable debug output
# DEBUG=ai:*

# Log level (error, warn, info, debug)
# LOG_LEVEL=info
