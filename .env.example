# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║  Ai — Environment Variables                                                  ║
# ║                                                                              ║
# ║  Copy this file to .env and fill in the values.                              ║
# ║  DO NOT commit your .env file to version control.                            ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

# ── Local AI Configuration ──

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# llama.cpp server URL (default: http://localhost:8080)
# LLAMACPP_BASE_URL=http://localhost:8080

# Default model to use (default: qwen2.5-coder:7b)
# AI_DEFAULT_MODEL=qwen2.5-coder:7b

# ── Optional: Database Connections ──

# PostgreSQL connection string (for DatabaseTool)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# MySQL connection string (for DatabaseTool)
# MYSQL_URL=mysql://user:password@localhost:3306/dbname

# ── Optional: Features ──

# Enable disk caching for AI responses (default: true)
# AI_CACHE_DISK=true

# Cache directory (default: ~/.cache/ai)
# AI_CACHE_DIR=

# Brain state directory (default: ~/.local/share/ai)
# AI_DATA_DIR=

# Dashboard port (default: 3210)
# AI_DASHBOARD_PORT=3210

# ── Optional: Development ──

# Node environment (development/production/test)
NODE_ENV=development

# Enable debug output
# DEBUG=ai:*

# Log level (error, warn, info, debug)
# LOG_LEVEL=info
