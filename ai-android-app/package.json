{
  "name": "ai-android-app",
  "version": "2.3.0",
  "description": "AI Assistant Android App - 120+ AI modules, fully offline, no external APIs. Built with React Native and Expo.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "build:android": "eas build --platform android --profile production",
    "build:android:local": "npx expo run:android --variant release",
    "build:apk": "eas build --platform android --profile apk",
    "build:debug": "eas build --platform android --profile debug",
    "build:preview": "eas build --platform android --profile preview",
    "prebuild": "expo prebuild --platform android",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "@expo/vector-icons": "^14.0.0",
    "expo-clipboard": "~7.0.0",
    "expo-haptics": "~14.0.0",
    "expo-file-system": "~18.0.0",
    "@react-native-async-storage/async-storage": "1.23.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0"
  },
  "private": true,
  "keywords": [
    "ai",
    "android",
    "apk",
    "offline",
    "local-ai",
    "react-native",
    "expo",
    "chat",
    "assistant"
  ]
}
