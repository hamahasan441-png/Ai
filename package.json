{
  "name": "ai",
  "version": "2.3.0",
  "description": "**1,886+ source files · 36+ modules · 39 tools · 50+ commands — ALL connected into one local AI.** Now with Structured Logging, Input Validation, Plugin SDK, Observability, and Startup Environment Validation. No external API required — fully local.",
  "main": "src/chat/index.ts",
  "types": "src/chat/index.ts",
  "exports": {
    ".": "./src/chat/index.ts",
    "./utils": "./src/utils/index.ts",
    "./services": "./src/services/index.ts",
    "./plugins": "./src/plugins/PluginSDK.ts"
  },
  "files": [
    "src/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "ai": "./src/entrypoints/cli.tsx"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "tsx --import ./src/utils/stubs/macro-globals.ts src/entrypoints/cli.tsx",
    "dev": "tsx --import ./src/utils/stubs/macro-globals.ts src/entrypoints/cli.tsx",
    "download-models": "node scripts/download-models.js",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run typecheck && npm run test",
    "prepack": "echo 'Note: This package requires tsx or a TypeScript runtime to execute the CLI entry point.'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamahasan441-png/Ai.git"
  },
  "keywords": [
    "ai",
    "local-ai",
    "offline",
    "chat",
    "code",
    "tools",
    "brain",
    "offline",
    "database",
    "cache",
    "plugin-sdk",
    "structured-logging",
    "code-analysis",
    "no-api",
    "self-hosted"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/hamahasan441-png/Ai/issues"
  },
  "homepage": "https://github.com/hamahasan441-png/Ai#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
